#include <iostream>
using namespace std;

int main() {
    int n, k;

    cout << "Enter size of array: ";
    cin >> n;

    int arr[n];

    cout << "Enter elements:\n";
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    cout << "Enter k: ";
    cin >> k;

    k = k % n;  // handle large k

    
    int temp[n];

   
    for(int i = 0; i < n; i++) {
        temp[i] = arr[(i + k) % n];
    }

    cout << "Rotated array:\n";
    for(int i = 0; i < n; i++) {
        cout << temp[i] << " ";
    }

    return 0;
}
