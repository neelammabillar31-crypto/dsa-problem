def twoSum(nums, target):
    nums.sort()   # sort the array first
    left = 0
    right = len(nums) - 1

    while left < right:
        current_sum = nums[left] + nums[right]

        if current_sum == target:
            return [nums[left], nums[right]]
        elif current_sum < target:
            left += 1
        else:
            right -= 1

# Example
nums = [2, 7, 11, 15]
target = 9
print(twoSum(nums, target))  # Output: [2, 7]
