#include <iostream>
using namespace std;

int main() {
    int n, k;
    cout << "Enter size: ";
    cin >> n;

    int arr[n];
    cout << "Enter elements: ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    cout << "Enter window size: ";
    cin >> k;

    int windowSum = 0;

    
    for (int i = 0; i < k; i++) {
        windowSum += arr[i];
    }

    int maxSum = windowSum;

    
    for (int i = k; i < n; i++) {
        windowSum += arr[i];       // add next
        windowSum -= arr[i - k];   // remove previous

        if (windowSum > maxSum)
            maxSum = windowSum;
    }

    cout << "Maximum sum: " << maxSum;

    return 0;
}
