#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter size: ";
    cin >> n;

    int height[n];
    cout << "Enter heights: ";
    for (int i = 0; i < n; i++) {
        cin >> height[i];
    }

    int left = 0, right = n - 1;
    int maxWater = 0;

    while (left < right) {
        int h = min(height[left], height[right]);
        int width = right - left;
        int area = h * width;

        if (area > maxWater)
            maxWater = area;

        
        if (height[left] < height[right])
            left++;
        else
            right--;
    }

    cout << "Maximum Water: " << maxWater;

    return 0;
}
