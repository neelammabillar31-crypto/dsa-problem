#include <iostream>
#include <stack>
using namespace std;

int main() {
    int n;
    cout << "Enter number of days: ";
    cin >> n;

    int price[n];
    cout << "Enter prices: ";
    for (int i = 0; i < n; i++) {
        cin >> price[i];
    }

    int span[n];
    stack<int> st; // store index

    for (int i = 0; i < n; i++) {

        
        while (!st.empty() && price[st.top()] <= price[i]) {
            st.pop();
        }

        
        if (st.empty())
            span[i] = i + 1;
        else
            span[i] = i - st.top();

        
        st.push(i);
    }

    cout << "Stock Span: ";
    for (int i = 0; i < n; i++) {
        cout << span[i] << " ";
    }

    return 0;
}
