#include <iostream>
#include <stack>
using namespace std;

int main() {
    string str;
    cout << "Enter string: ";
    cin >> str;

    stack<char> st;

    
    for (char ch : str) {
        st.push(ch);
    }

    
    string reversed = "";
    while (!st.empty()) {
        reversed += st.top();
        st.pop();
    }

    cout << "Reversed string: " << reversed;

    return 0;
}
