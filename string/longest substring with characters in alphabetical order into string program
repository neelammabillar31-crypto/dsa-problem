#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cout << "Enter a string: ";
    cin >> s;

    int maxLen = 1, curLen = 1;
    string longest = s.substr(0,1);
    int start = 0;

    for (int i = 1; i < s.length(); i++) {
        if (s[i] >= s[i-1]) {
            curLen++;
        } else {
            curLen = 1;
            start = i;
        }

        if (curLen > maxLen) {
            maxLen = curLen;
            longest = s.substr(start, curLen);
        }
    }

    cout << "Longest alphabetical substring: " << longest << endl;
    return 0;
}
