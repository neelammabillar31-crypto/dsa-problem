struct Node* oddEvenList(struct Node* head) {
    if (!head) return head;

    struct Node* odd = head;
    struct Node* even = head->next;
    struct Node* evenHead = even;

    while (even && even->next) {
        odd->next = even->next;
        odd = odd->next;

        even->next = odd->next;
        even = even->next;
    }

    odd->next = evenHead;
    return head;
}
