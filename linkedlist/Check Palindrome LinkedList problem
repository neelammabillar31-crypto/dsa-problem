int isPalindrome(struct Node* head) {
    struct Node *slow = head, *fast = head;
    struct Node *prev = NULL, *next = NULL;

    
    while (fast != NULL && fast->next != NULL) {
        fast = fast->next->next;

        next = slow->next;
        slow->next = prev;
        prev = slow;
        slow = next;
    }

    
    if (fast != NULL) slow = slow->next;

    
    while (prev != NULL && slow != NULL) {
        if (prev->data != slow->data)
            return 0;

        prev = prev->next;
        slow = slow->next;
    }

    return 1;
}
